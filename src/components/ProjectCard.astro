---
const {
  title,
  description,
  image,
  playstore,
  tech = []
} = Astro.props;
---

<section class="project-section ">
  <div class="container">
    <div class="project-grid">
      
      <!-- Image Side with 3D Effect -->
      <div class="image-wrapper">
        <div class="image-glow"></div>
        <div class="image-container">
          <img 
            src={image} 
            alt={title}
            class="project-image"
            loading="eager"
          />
          <div class="image-overlay"></div>
        </div>
        <div class="floating-badge">
          <span class="badge-text">Live Project</span>
          <div class="badge-pulse"></div>
        </div>
      </div>

      <!-- Content Side -->
      <div class="content-wrapper">
        <div class="content-header">
          <span class="section-label">
            <span class="label-line"></span>
            Featured Project
          </span>
          <h2 class="project-title">{title}</h2>
        </div>

        <p class="project-description">{description}</p>

        <!-- Tech Stack with Hover Effects -->
        <div class="tech-section">
          <span class="tech-label">Tech Stack</span>
          <div class="tech-grid">
            {tech.map((item, index) => (
              <div class="tech-item" style={`--delay: ${index * 50}ms`}>
                <span class="tech-dot"></span>
                <span class="tech-name">{item}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- CTA Button -->
        <div class="cta-wrapper">
          <a
            href={playstore}
            target="_blank"
            rel="noopener noreferrer"
            class="playstore-btn"
          >
            <span class="btn-content">
              <svg class="play-icon" viewBox="0 0 24 24" fill="currentColor">
                <path d="M3 20.5V3.5C3 2.91 3.34 2.39 3.84 2.15L13.69 12L3.84 21.85C3.34 21.6 3 21.09 3 20.5ZM16.81 15.12L6.05 21.34L14.54 12.85L16.81 15.12ZM20.16 10.81C20.5 11.08 20.75 11.5 20.75 12C20.75 12.5 20.53 12.9 20.18 13.18L17.89 14.5L15.39 12L17.89 9.5L20.16 10.81ZM6.05 2.66L16.81 8.88L14.54 11.15L6.05 2.66Z"/>
              </svg>
              <span class="btn-text">
                <span class="btn-small">Get it on</span>
                <span class="btn-large">Google Play</span>
              </span>
            </span>
            <div class="btn-glow"></div>
          </a>
        </div>
      </div>

    </div>
  </div>
</section>


<style>
  /* REMOVE background isolation - let global.css handle it */
  .project-section {
    position: relative;
    padding: 6rem 1.5rem;
    /* No background here - inherits from body */
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .project-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: center;
  }

  @media (min-width: 968px) {
    .project-grid {
      grid-template-columns: 1.1fr 1fr;
      gap: 6rem;
    }
  }

  /* Image Styles */
  .image-wrapper {
    position: relative;
    perspective: 1000px;
  }

  .image-container {
    position: relative;
    border-radius: 2rem;
    overflow: hidden;
    transform-style: preserve-3d;
    transition: transform 0.6s cubic-bezier(0.23, 1, 0.32, 1);
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
  }

  :global([data-theme="dark"]) .image-container {
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
  }

  .image-wrapper:hover .image-container {
    transform: rotateY(-5deg) rotateX(5deg) scale(1.02);
  }

  .project-image {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.6s cubic-bezier(0.23, 1, 0.32, 1);
  }

  .image-wrapper:hover .project-image {
    transform: scale(1.05);
  }

  /* Content Styles - Use CSS variables */
  .content-wrapper {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .content-header {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .section-label {
    display: flex;
    align-items: center;
    gap: 1rem;
    color: #22c55e;
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .label-line {
    width: 3rem;
    height: 2px;
    background: linear-gradient(90deg, #22c55e, transparent);
  }

  .project-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    color: rgb(var(--gray-dark));
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .project-description {
    font-size: 1.125rem;
    line-height: 1.8;
    color: rgb(var(--gray-dark));
    opacity: 0.85;
    max-width: 540px;
  }

  /* Tech Stack */
  .tech-section {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .tech-label {
    font-size: 0.875rem;
    color: rgb(var(--gray-dark));
    opacity: 0.6;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .tech-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .tech-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1rem;
    background: rgba(var(--gray-light), 0.6);
    border: 1px solid rgba(var(--gray-dark), 0.15);
    border-radius: 0.75rem;
    color: rgb(var(--gray-dark));
    font-size: 0.875rem;
    font-weight: 500;
    transition: all 0.3s ease;
  }

  .tech-item:hover {
    background: rgba(34, 197, 94, 0.15);
    border-color: rgba(34, 197, 94, 0.4);
    transform: translateY(-2px);
  }

  .tech-dot {
    width: 6px;
    height: 6px;
    background: #22c55e;
    border-radius: 50%;
  }

  /* CTA Button */
  .cta-wrapper {
    margin-top: 1rem;
  }

  .playstore-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    padding: 1rem 2rem;
    background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
    border-radius: 1rem;
    text-decoration: none;
    overflow: hidden;
    transition: transform 0.3s ease;
    box-shadow: 0 20px 40px -10px rgba(34, 197, 94, 0.3);
  }

  .playstore-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 30px 60px -15px rgba(34, 197, 94, 0.4);
  }

  .btn-content {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .play-icon {
    width: 28px;
    height: 28px;
    color: white;
  }

  .btn-text {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }

  .btn-small {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.9);
    font-weight: 500;
  }

  .btn-large {
    font-size: 1.25rem;
    color: white;
    font-weight: 700;
  }

  /* Responsive */
  @media (max-width: 967px) {
    .project-section {
      padding: 4rem 1rem;
    }
    
    .image-wrapper {
      order: -1;
    }
  }
</style>
