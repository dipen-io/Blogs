---
const {
  title,
  description,
  image,
  playstore,
  tech = []
} = Astro.props;
---

<section class="project-section ">
  <div class="container">
    <div class="project-grid">
      
      <!-- Image Side with 3D Effect -->
      <div class="image-wrapper">
        <div class="image-glow"></div>
        <div class="image-container">
          <img 
            src={image} 
            alt={title}
            class="project-image"
            loading="eager"
          />
          <div class="image-overlay"></div>
        </div>
        <div class="floating-badge">
          <span class="badge-text">Live Project</span>
          <div class="badge-pulse"></div>
        </div>
      </div>

      <!-- Content Side -->
      <div class="content-wrapper">
        <div class="content-header">
          <span class="section-label">
            <span class="label-line"></span>
            Featured Project
          </span>
          <h2 class="project-title">{title}</h2>
        </div>

        <p class="project-description">{description}</p>

        <!-- Tech Stack with Hover Effects -->
        <div class="tech-section">
          <span class="tech-label">Tech Stack</span>
          <div class="tech-grid">
            {tech.map((item, index) => (
              <div class="tech-item" style={`--delay: ${index * 50}ms`}>
                <span class="tech-dot"></span>
                <span class="tech-name">{item}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- CTA Button -->
        <div class="cta-wrapper">
          <a
            href={playstore}
            target="_blank"
            rel="noopener noreferrer"
            class="playstore-btn"
          >
            <span class="btn-content">
              <svg class="play-icon" viewBox="0 0 24 24" fill="currentColor">
                <path d="M3 20.5V3.5C3 2.91 3.34 2.39 3.84 2.15L13.69 12L3.84 21.85C3.34 21.6 3 21.09 3 20.5ZM16.81 15.12L6.05 21.34L14.54 12.85L16.81 15.12ZM20.16 10.81C20.5 11.08 20.75 11.5 20.75 12C20.75 12.5 20.53 12.9 20.18 13.18L17.89 14.5L15.39 12L17.89 9.5L20.16 10.81ZM6.05 2.66L16.81 8.88L14.54 11.15L6.05 2.66Z"/>
              </svg>
              <span class="btn-text">
                <span class="btn-small">Get it on</span>
                <span class="btn-large">Google Play</span>
              </span>
            </span>
            <div class="btn-glow"></div>
          </a>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .project-section {
    position: relative;
    padding: 6rem 1.5rem;
    /* REMOVE the hardcoded background - let global.css handle it */
    background: transparent;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .project-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: center;
  }

  @media (min-width: 968px) {
    .project-grid {
      grid-template-columns: 1.1fr 1fr;
      gap: 6rem;
    }
  }

  /* Image Styles */
  .image-wrapper {
    position: relative;
    perspective: 1000px;
  }

  .image-glow {
    position: absolute;
    inset: -20px;
    background: linear-gradient(135deg, rgba(34, 197, 94, 0.3), rgba(74, 222, 128, 0.15));
    filter: blur(60px);
    border-radius: 3rem;
    opacity: 0.6;
    animation: pulse-glow 4s ease-in-out infinite;
  }

  @keyframes pulse-glow {
    0%, 100% { opacity: 0.4; transform: scale(1); }
    50% { opacity: 0.7; transform: scale(1.05); }
  }

  .image-container {
    position: relative;
    border-radius: 2rem;
    overflow: hidden;
    transform-style: preserve-3d;
    transition: transform 0.6s cubic-bezier(0.23, 1, 0.32, 1);
    box-shadow: 
      0 25px 50px -12px rgba(0, 0, 0, 0.15),
      0 0 0 1px rgba(0, 0, 0, 0.05);
  }

  .image-wrapper:hover .image-container {
    transform: rotateY(-5deg) rotateX(5deg) scale(1.02);
  }

  .project-image {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.6s cubic-bezier(0.23, 1, 0.32, 1);
  }

  .image-wrapper:hover .project-image {
    transform: scale(1.05);
  }

  .image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      transparent 0%,
      rgba(34, 197, 94, 0.1) 50%,
      transparent 100%
    );
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .image-wrapper:hover .image-overlay {
    opacity: 1;
  }

  .floating-badge {
    position: absolute;
    top: -10px;
    right: -10px;
    background: linear-gradient(135deg, #22c55e, #16a34a);
    padding: 0.75rem 1.25rem;
    border-radius: 2rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    box-shadow: 0 10px 30px -5px rgba(34, 197, 94, 0.4);
    animation: float 3s ease-in-out infinite;
    z-index: 10;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  .badge-text {
    color: white;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.025em;
  }

  .badge-pulse {
    width: 8px;
    height: 8px;
    background: white;
    border-radius: 50%;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.2); }
  }

  /* Content Styles - Use CSS variables from global.css */
  .content-wrapper {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .content-header {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .section-label {
    display: flex;
    align-items: center;
    gap: 1rem;
    color: #22c55e; /* Keep accent color */
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .label-line {
    width: 3rem;
    height: 2px;
    background: linear-gradient(90deg, #22c55e, transparent);
  }

  .project-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    /* USE CSS VARIABLE for automatic dark mode switching */
    color: rgb(var(--gray-dark));
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .project-description {
    font-size: 1.125rem;
    line-height: 1.8;
    /* USE CSS VARIABLE */
    color: rgb(var(--gray-dark));
    opacity: 0.8;
    max-width: 540px;
  }

  /* Tech Stack - Use CSS variables */
  .tech-section {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .tech-label {
    font-size: 0.875rem;
    /* USE CSS VARIABLE */
    color: rgb(var(--gray-dark));
    opacity: 0.6;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .tech-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .tech-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1rem;
    /* USE CSS VARIABLES for background and border */
    background: rgba(var(--gray-light), 0.5);
    border: 1px solid rgba(var(--gray-dark), 0.1);
    border-radius: 0.75rem;
    /* USE CSS VARIABLE */
    color: rgb(var(--gray-dark));
    font-size: 0.875rem;
    font-weight: 500;
    transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1);
    animation: fade-in-up 0.6s ease-out backwards;
    animation-delay: var(--delay);
    cursor: default;
  }

  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .tech-item:hover {
    background: rgba(34, 197, 94, 0.1);
    border-color: rgba(34, 197, 94, 0.3);
    transform: translateY(-2px);
    box-shadow: 0 10px 20px -5px rgba(34, 197, 94, 0.15);
  }

  .tech-dot {
    width: 6px;
    height: 6px;
    background: #22c55e;
    border-radius: 50%;
    box-shadow: 0 0 10px rgba(34, 197, 94, 0.5);
  }

  /* CTA Button */
  .cta-wrapper {
    margin-top: 1rem;
  }

  .playstore-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    padding: 1rem 2rem;
    background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
    border-radius: 1rem;
    text-decoration: none;
    overflow: hidden;
    transition: transform 0.3s cubic-bezier(0.23, 1, 0.32, 1);
    box-shadow: 
      0 20px 40px -10px rgba(34, 197, 94, 0.3),
      0 0 0 1px rgba(255, 255, 255, 0.1) inset;
  }

  .playstore-btn:hover {
    transform: translateY(-2px) scale(1.02);
    box-shadow: 
      0 30px 60px -15px rgba(34, 197, 94, 0.4),
      0 0 0 1px rgba(255, 255, 255, 0.2) inset;
  }

  .playstore-btn:active {
    transform: translateY(0) scale(0.98);
  }

  .btn-content {
    display: flex;
    align-items: center;
    gap: 1rem;
    position: relative;
    z-index: 2;
  }

  .play-icon {
    width: 28px;
    height: 28px;
    color: white;
    filter: drop-shadow(0 2px 4px rgba(0,0,0,0.2));
  }

  .btn-text {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }

  .btn-small {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.9);
    font-weight: 500;
  }

  .btn-large {
    font-size: 1.25rem;
    color: white;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .btn-glow {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, transparent 0%, rgba(255,255,255,0.2) 50%, transparent 100%);
    transform: translateX(-100%);
    transition: transform 0.6s ease;
  }

  .playstore-btn:hover .btn-glow {
    transform: translateX(100%);
  }

  /* Responsive */
  @media (max-width: 967px) {
    .project-section {
      padding: 4rem 1rem;
    }
    
    .image-wrapper {
      order: -1;
    }
    
    .floating-badge {
      top: 10px;
      right: 10px;
    }
  }
</style>
